{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://inspecta.dev/schemas/policy-pack-schema-1.0.0.json",
    "title": "inspecta policy pack",
    "type": "object",
    "required": [
        "schema_version",
        "pack_id",
        "display_name",
        "target_profile",
        "rules"
    ],
    "properties": {
        "schema_version": {
            "const": "1.0.0"
        },
        "pack_id": {
            "type": "string",
            "pattern": "^[a-z0-9._-]{3,64}$"
        },
        "display_name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 120
        },
        "description": {
            "type": "string",
            "maxLength": 800
        },
        "target_profile": {
            "type": "string",
            "enum": [
                "default",
                "office",
                "developer",
                "gamer",
                "server",
                "refurbish_shop",
                "enterprise_it",
                "field_service",
                "resale_audit"
            ]
        },
        "severity_model": {
            "type": "string",
            "enum": [
                "low-medium-high",
                "info-warning-critical"
            ],
            "default": "info-warning-critical"
        },
        "rules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "title",
                    "condition",
                    "action"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^[A-Z0-9_]{3,64}$"
                    },
                    "title": {
                        "type": "string",
                        "minLength": 3,
                        "maxLength": 160
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "critical"
                        ],
                        "default": "warning"
                    },
                    "condition": {
                        "type": "string",
                        "description": "Expression over report keys, e.g. scores.storage < 60"
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "warn",
                            "fail",
                            "recommend"
                        ]
                    },
                    "message": {
                        "type": "string",
                        "maxLength": 400
                    }
                },
                "additionalProperties": false
            }
        },
        "metadata": {
            "type": "object",
            "properties": {
                "author": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}